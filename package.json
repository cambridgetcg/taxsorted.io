{
  "name": "taxsorted",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "engine",
    "frontend",
    "api"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspace frontend",
    "validate:uk-personal-tax": "node scripts/validate-uk-personal-tax.mjs",
    "validate:uk-politics": "node scripts/validate-uk-politics.mjs",
    "validate:uk-tax-system": "npm run validate:tax-system --workspace api",
    "validate:uk-tax-industry": "npm run validate:tax-industry --workspace api",
    "validate:uk-charities": "npm run validate:charities --workspace api",
    "validate:uk-observer-accountability": "npm run validate:observer-accountability-candidate --workspace api",
    "validate:uk-public-funding": "npm run validate:public-funding --workspace api",
    "validate:learn": "npm run validate:uk-personal-tax && npm run validate:uk-politics && npm run validate:uk-tax-system && npm run validate:uk-tax-industry && npm run validate:uk-charities && npm run validate:uk-observer-accountability && npm run validate:uk-public-funding",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
