{
  "name": "taxsorted",
  "private": true,
  "workspaces": [
    "engine",
    "frontend",
    "api"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspace frontend",
    "validate:uk-personal-tax": "node scripts/validate-uk-personal-tax.mjs",
    "validate:uk-politics": "node scripts/validate-uk-politics.mjs",
    "validate:uk-tax-system": "npm run validate:tax-system --workspace api",
    "validate:uk-tax-industry": "npm run validate:tax-industry --workspace api",
    "validate:learn": "npm run validate:uk-personal-tax && npm run validate:uk-politics && npm run validate:uk-tax-system && npm run validate:uk-tax-industry",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
