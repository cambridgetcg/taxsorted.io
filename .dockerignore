# Build context is the repo root — keep secrets and junk out of the image.
**/node_modules
**/.env
**/.env.*
.git
.github
frontend/out
frontend/.next
# The API reads two reviewed JSON corpora at boot. Keep every other research
# file out of the image while allowing only those runtime data directories.
research/*
!research/uk/
research/uk/*
!research/uk/tax-system/
!research/uk/tax-industry/
research/uk/tax-system/*
research/uk/tax-industry/*
!research/uk/tax-system/data/
!research/uk/tax-system/data/**
!research/uk/tax-industry/data/
!research/uk/tax-industry/data/**
infrastructure
**/*.pem
**/*.key
