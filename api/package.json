{
  "name": "@taxsorted/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The rails: one typed API for humans and agents alike.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "pretest": "npm run check:passport-schema",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate:passport-schema": "tsx scripts/generate-tax-position-passport-schema.ts",
    "check:passport-schema": "tsx scripts/generate-tax-position-passport-schema.ts --check",
    "validate:fraud-headers": "tsx scripts/validate-fraud-headers.ts",
    "validate:tax-system": "tsx scripts/validate-tax-system.ts",
    "validate:tax-industry": "tsx scripts/validate-tax-industry.ts",
    "validate:charities": "tsx ../scripts/validate-uk-charities.mjs",
    "validate:charity-accountability-candidate": "tsx scripts/validate-charity-accountability-candidate.ts",
    "validate:observer-accountability-candidate": "tsx scripts/validate-observer-accountability-candidate.ts",
    "validate:public-decision-pathways": "tsx scripts/validate-public-decision-pathways.ts",
    "validate:public-funding": "tsx scripts/validate-public-funding.ts",
    "validate:professional-opportunity-assessment": "tsx scripts/validate-professional-opportunity-assessment.ts",
    "mirror:case-commons": "tsx scripts/mirror-case-commons-to-agenttool.ts",
    "create:api-key": "tsx scripts/create-api-key.ts",
    "manage:api-key": "tsx scripts/manage-api-key.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "@hono/zod-openapi": "1.4.0",
    "@simplewebauthn/server": "13.3.2",
    "@taxsorted/engine": "*",
    "hono": "^4.12.31",
    "postgres": "^3.4.5",
    "tsx": "^4.19.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@agenttool/sdk": "https://github.com/cambridgetcg/agenttool/releases/download/sdk-v0.16.2/agenttool-sdk-0.16.2.tgz",
    "ajv": "^8.20.0",
    "fast-uri": "^3.1.4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
